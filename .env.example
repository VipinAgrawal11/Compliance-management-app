# Supabase project credentials.
# Find these in: Supabase Dashboard -> Project Settings -> API
# These are PUBLIC values (safe to ship to the browser). RLS protects your data.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: Never put the service_role key in a VITE_* variable.
# It bypasses Row Level Security and must stay server-side only
# (used solely by scripts/seed.mjs, read from the environment).
